{
  "name": "sequelize-db",
  "version": "1.0.0",
  "main": "app.js",
  "type": "module",
  "scripts": {
    "start": "node --env-file=.env src/app.js",
    "dev": "node --watch --env-file=.env src/app.js",
    "lint": "eslint . --ext .js --fix",
    "test": "node --test --env-file=.env",
    "test:coverage": "c8 --all --reporter=html --reporter=text node --test",
    "seed": "node --env-file=.env scripts/seed.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "cookie-parser": "^1.4.7",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.15.6",
    "pg-hstore": "^2.3.4",
    "qs": "^6.14.0",
    "sequelize": "^6.37.7",
    "slug": "^10.0.0",
    "zod": "^3.24.4"
  },
  "imports": {
    "#*": "./src/*"
  },
  "c8": {
    "exclude": [
      ".config.*",
      "test/*",
      "src/app.js",
      "src/config/*",
      "src/routes/*"
    ],
    "include": [
      "src/"
    ],
    "reporter": "text",
    "all": true,
    "check-coverage": true,
    "branches": 0,
    "functions": 0,
    "lines": 0,
    "statements": 0
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.1",
    "@types/qs": "^6.9.18",
    "@types/slug": "^5.0.9",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "c8": "^10.1.3",
    "eslint": "^9.26.0",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^7.2.1"
  }
}
